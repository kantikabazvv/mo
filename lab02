import numpy as np
import matplotlib.pyplot as plt

%matplotlib inline
plt.rcParams['figure.figsize'] = [10, 8]

def rosenbrock(xy, alpha=1):
    x, y = xy
    return alpha * (x**2 - y)**2 + (x - 1)**2

def rosenbrock_grad(xy, alpha=1):
    x, y = xy
    dfdx = 4 * alpha * x * (x**2 - y) + 2 * (x - 1)
    dfdy = -2 * alpha * (x**2 - y)
    return np.array([dfdx, dfdy])

def quadratic(xy):
    x, y = xy
    return x**2 + 4 * y**2

def quadratic_grad(xy):
    x, y = xy
    return np.array([2 * x, 8 * y])

def quadratic20(xy):
    x, y = xy
    return x**2 + 20 * y**2

def quadratic20_grad(xy):
    x, y = xy
    return np.array([2 * x, 40 * y])

def himmelblau(xy):
    x, y = xy
    return (x**2 + y - 11)**2 + (x + y**2 - 7)**2

def himmelblau_grad(xy):
    x, y = xy
    dfdx = 4 * x * (x**2 + y - 11) + 2 * (x + y**2 - 7)
    dfdy = 2 * (x**2 + y - 11) + 4 * y * (x + y**2 - 7)
    return np.array([dfdx, dfdy])

