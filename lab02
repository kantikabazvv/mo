def golden_section_search(f, a=0, b=1, eps=1e-5):
    gr = (np.sqrt(5) - 1) / 2
    
    x1 = b - gr * (b - a)
    x2 = a + gr * (b - a)
    f1 = f(x1)
    f2 = f(x2)
    
    nfev = 2
    
    while abs(b - a) > eps:
        if f1 < f2:
            b = x2
            x2 = x1
            f2 = f1
            x1 = b - gr * (b - a)
            f1 = f(x1)
        else:
            a = x1
            x1 = x2
            f1 = f2
            x2 = a + gr * (b - a)
            f2 = f(x2)
        nfev += 1
    
    x_min = (a + b) / 2
    return x_min, nfev

def steepest_descent(f, grad, x0, eps=1e-3, max_iter=1000):
    x = np.array(x0, dtype=float)
    trajectory = [x.copy()]
    func_calls = 0
    grad_calls = 0
    
    for k in range(max_iter):
        g = grad(x)
        grad_calls += 1
        norm_g = np.linalg.norm(g)
        
        if norm_g < eps:
            break

        def phi(alpha):
            return f(x - alpha * g)
        
        alpha, nfev = golden_section_search(phi, a=0, b=10, eps=1e-4)
        func_calls += nfev
        
        x = x - alpha * g
        trajectory.append(x.copy())
    
    return np.array(trajectory), k + 1, func_calls, grad_calls

def gradient_descent_spalling(f, grad, x0, eps=1e-3, gamma=0.5, omega=0.1, max_iter=1000):
    x = np.array(x0, dtype=float)
    trajectory = [x.copy()]
    func_calls = 1
    grad_calls = 0
    
    for k in range(max_iter):
        g = grad(x)
        grad_calls += 1
        norm_g = np.linalg.norm(g)
        
        if norm_g < eps:
            break
        
        step = 1.0
        fx = f(x)
        
        while True:
            x_new = x - step * g
            f_new = f(x_new)
            func_calls += 1
            
            if fx - f_new > omega * step * norm_g**2:
                break
            step *= gamma
        
        x = x - step * g
        trajectory.append(x.copy())
    
    return np.array(trajectory), k + 1, func_calls, grad_calls

def plot_optimization(f, trajectory, title, bounds=(-3, 3), levels=30):
    x_vals = np.linspace(bounds[0], bounds[1], 200)
    y_vals = np.linspace(bounds[0], bounds[1], 200)
    X, Y = np.meshgrid(x_vals, y_vals)
    
    Z = np.zeros_like(X)
    for i in range(X.shape[0]):
        for j in range(X.shape[1]):
            Z[i, j] = f([X[i, j], Y[i, j]])
    
    plt.figure(figsize=(10, 8))
    contour = plt.contour(X, Y, Z, levels=levels, cmap='viridis', alpha=0.7)
    plt.colorbar(contour, label='f(x, y)')
    
    traj = np.array(trajectory)
    plt.plot(traj[:, 0], traj[:, 1], 'r.-', linewidth=2, markersize=6, label='Траектория')
    plt.scatter(traj[0, 0], traj[0, 1], c='green', s=150, label='Старт', marker='o')
    plt.scatter(traj[-1, 0], traj[-1, 1], c='blue', s=250, label='Финиш', marker='*')
    
    plt.xlabel('x')
    plt.ylabel('y')
    plt.title(title)
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.axis('equal')
    plt.show()

